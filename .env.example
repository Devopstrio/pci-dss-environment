# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="PCI-DSS Environment"

# Security & Crypto
SECRET_KEY=pcisupersecret123
ACCESS_TOKEN_EXPIRE_MINUTES=15 # PCI requires short sessions
KMS_MASTER_KEY_ID=mock-kms-key-123

# Database (CDE Segmented)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pci_db

# Redis / Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# Compliance Settings
ENFORCE_MFA=true
AUDIT_LOGGING_ENABLED=true
DATA_RETENTION_DAYS=365

# Grafana Dashboard
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_PASSWORD=admin
